# 通义千问 DashScope
OPENAI_API_KEY=your_dashscope_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-vl-plus

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# 七牛 Kodo（可选：帧缓存降成本；留空则 base64 直传，功能不受影响）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_CDN_DOMAIN=

# Cost control
MAX_REQUESTS_PER_MINUTE=10
TTS_MAX_REQUESTS_PER_MINUTE=60
LLM_MAX_TOKENS=300
REPLY_DETAILED_MAX_TOKENS=1200
REPLY_DETAILED_MIN_SENTENCES=5

# 会话记忆（服务端持久化）
MEMORY_TURN_LIMIT=12
MEMORY_MAX_SESSIONS_PER_USER=5

# Tavily MCP（本地 Docker SSE，npm run dev:mcp）
TAVILY_API_KEY=tvly-your-key-here
MCP_ENABLED=true
MCP_SSE_URL=http://localhost:8000/sse
MCP_PORT=8000
MCP_DOCKER_IMAGE=acuvity/mcp-server-tavily:0.2.12

# 网页查询 Skill（内置，无需 MCP 也可联网）
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=bing_rss
SEARXNG_INSTANCES=https://searx.be,https://search.bus-hit.me
WEB_SEARCH_MAX_RESULTS=3

# 云端 TTS（DashScope CosyVoice，cc404喵 推荐女声）
TTS_ENABLED=true
TTS_MODEL=cosyvoice-v3-flash
TTS_VOICE=longxiaochun_v3
TTS_RATE=1.05
TTS_FORMAT=mp3
TTS_MAX_CHARS=500
