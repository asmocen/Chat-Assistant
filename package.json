{
  "name": "chat-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "AI Visual Dialogue Assistant - see, hear, and respond",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:all": "concurrently -n server,client,mcp -c blue,green,magenta \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:mcp\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:mcp": "node scripts/start-tavily-mcp.mjs",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "sync": "node scripts/git-sync.mjs sync",
    "sync:status": "node scripts/git-sync.mjs status",
    "sync:pull": "node scripts/git-sync.mjs pull",
    "sync:push": "node scripts/git-sync.mjs push",
    "pr:new": "node scripts/pr-workflow.mjs new",
    "pr:push": "node scripts/pr-workflow.mjs push",
    "pr:check": "node scripts/pr-workflow.mjs check"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
